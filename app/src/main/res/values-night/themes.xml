<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Night-mode override: in dark mode the status bar is part of the dark chrome.
        windowLightStatusBar=false ensures icons are white (not dark).
    -->
    <style name="Theme.FitnessApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>
</resources>

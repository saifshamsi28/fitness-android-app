<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <!-- Production HTTPS: explicitly trust system CAs (fixes Let's Encrypt / Render SSL on all Android versions) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext HTTP only to local dev addresses (emulator + physical device) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">0.0.0.0</domain>
        <domain includeSubdomains="true">10.163.19.205</domain>
        <domain includeSubdomains="true">10.163.3.176</domain>
    </domain-config>

</network-security-config>
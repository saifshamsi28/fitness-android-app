<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft outer glow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
            <size android:width="132dp" android:height="132dp" />
        </shape>
    </item>
    <!-- White circle -->
    <item
        android:top="8dp"
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
            <size android:width="116dp" android:height="116dp" />
        </shape>
    </item>
</layer-list>

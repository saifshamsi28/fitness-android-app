<?xml version="1.0" encoding="utf-8"?>
<!-- Full-page skeleton for the profile screen while data is loading -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- ===== Profile header skeleton ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:orientation="vertical"
        android:background="@color/primary_light"
        android:paddingTop="36dp"
        android:paddingBottom="44dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_horizontal">

        <!-- Avatar circle placeholder -->
        <View
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/shimmer_bg_circle"
            android:alpha="0.5"
            android:layout_marginBottom="14dp" />

        <!-- Name placeholder -->
        <View
            android:layout_width="140dp"
            android:layout_height="16dp"
            android:background="@drawable/shimmer_bg_rect"
            android:alpha="0.5"
            android:layout_marginBottom="8dp" />

        <!-- Email placeholder -->
        <View
            android:layout_width="100dp"
            android:layout_height="12dp"
            android:background="@drawable/shimmer_bg_rect"
            android:alpha="0.5" />
    </LinearLayout>

    <!-- ===== Stats row skeleton ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginTop="-22dp"
        android:layout_marginBottom="18dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/gray_light">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center">
                <View android:layout_width="40dp" android:layout_height="16dp" android:background="@drawable/shimmer_bg_rect" />
                <View android:layout_width="50dp" android:layout_height="11dp" android:layout_marginTop="6dp" android:background="@drawable/shimmer_bg_rect" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/gray_light">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center">
                <View android:layout_width="40dp" android:layout_height="16dp" android:background="@drawable/shimmer_bg_rect" />
                <View android:layout_width="50dp" android:layout_height="11dp" android:layout_marginTop="6dp" android:background="@drawable/shimmer_bg_rect" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/gray_light">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp"
                android:gravity="center">
                <View android:layout_width="40dp" android:layout_height="16dp" android:background="@drawable/shimmer_bg_rect" />
                <View android:layout_width="50dp" android:layout_height="11dp" android:layout_marginTop="6dp" android:background="@drawable/shimmer_bg_rect" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ===== Account Info skeleton ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Section title -->
        <View
            android:layout_width="140dp"
            android:layout_height="14dp"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/shimmer_bg_rect" />

        <!-- Info card placeholder -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/gray_light"
            android:layout_marginBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="16dp">
                    <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/shimmer_bg_circle" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <View android:layout_width="60dp" android:layout_height="10dp" android:background="@drawable/shimmer_bg_rect" />
                        <View android:layout_width="120dp" android:layout_height="14dp" android:layout_marginTop="5dp" android:background="@drawable/shimmer_bg_rect" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">
                    <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/shimmer_bg_circle" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <View android:layout_width="80dp" android:layout_height="10dp" android:background="@drawable/shimmer_bg_rect" />
                        <View android:layout_width="150dp" android:layout_height="14dp" android:layout_marginTop="5dp" android:background="@drawable/shimmer_bg_rect" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" />

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="16dp">
                    <View android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/shimmer_bg_circle" android:layout_marginEnd="14dp" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <View android:layout_width="90dp" android:layout_height="10dp" android:background="@drawable/shimmer_bg_rect" />
                        <View android:layout_width="100dp" android:layout_height="14dp" android:layout_marginTop="5dp" android:background="@drawable/shimmer_bg_rect" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bullet_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="#FAFAFA">

    <LinearLayout
        android:id="@+id/bullet_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- LEFT ACCENT BAR (color set from Java) -->
        <View
            android:id="@+id/accent_bar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#1E88E5" />

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- Icon + Label row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <!-- Icon in a small circle -->
                <LinearLayout
                    android:id="@+id/icon_circle"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/shimmer_bg_circle"
                    android:gravity="center"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:id="@+id/bullet_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:gravity="center" />
                </LinearLayout>

                <TextView
                    android:id="@+id/bullet_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.07"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/bullet_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#546E7A"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginStart="40dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
